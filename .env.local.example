# ============================================================
# Repararlo · Variables de entorno (copiá este archivo como .env.local)
# ============================================================

# --- Supabase (base de datos, login, storage) ---
# Supabase → tu proyecto → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Emails de recordatorio (Resend, gratis) — OPCIONAL ---
# resend.com → API Keys. Si lo dejás vacío, no se envían emails (no rompe nada).
RESEND_API_KEY=
# Remitente. Para probar sin dominio propio usá el de abajo (solo llega a tu email).
# Con dominio verificado en Resend: "Repararlo <noreply@repararlo.com.ar>"
EMAIL_FROM=Repararlo <onboarding@resend.dev>

# --- Cron de recordatorios ---
# Poné cualquier texto largo y aleatorio (ej: un password generado).
CRON_SECRET=

# --- URL pública del sitio (para los links de los emails) ---
NEXT_PUBLIC_SITE_URL=https://repararlo.com.ar
